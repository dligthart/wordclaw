# WordClaw Environment Configuration
# Copy this file to .env and adjust as needed:
#   cp .env.example .env

# Server port (default: 4000)
PORT=4000

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/wordclaw

# API auth and policy controls
# AUTH_REQUIRED=true enforces API key auth on /api routes.
# AUTH_REQUIRED=false still leaves write routes credentialed unless
# ALLOW_INSECURE_LOCAL_ADMIN=true is also enabled in non-production.
AUTH_REQUIRED=true

# Optional local-only escape hatch for manual development without API keys.
# This must remain false in any shared or preview environment.
ALLOW_INSECURE_LOCAL_ADMIN=false

# OpenAI embeddings for semantic search (/api/search/semantic)
# Leave blank to disable semantic search. Discovery surfaces will report
# vector RAG as disabled until this is configured.
OPENAI_API_KEY=

# Optional embedding guardrails
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_MAX_PER_MINUTE=30
OPENAI_EMBEDDING_DAILY_BUDGET=2000
OPENAI_EMBEDDING_RETRIES=3
OPENAI_EMBEDDING_RETRY_BASE_MS=500

# API key to scope map (comma-separated):
#   key=scopes|pipe|separated
# Scopes: content:read, content:write, audit:read, admin
API_KEYS=writer=content:read|content:write|audit:read,reader=content:read|audit:read

# Experimental revenue / payout surfaces are disabled by default.
# Set to true only if you explicitly want the earnings route, MCP tool,
# and payout-related workers enabled in this environment.
ENABLE_EXPERIMENTAL_REVENUE=false

# Experimental entitlement delegation is disabled by default.
# Set to true only if you explicitly want subordinate grant-sharing APIs.
ENABLE_EXPERIMENTAL_DELEGATION=false

# Experimental autonomous-run APIs are disabled by default outside tests.
# Set to true only if you explicitly want run-definition and run-control surfaces.
ENABLE_EXPERIMENTAL_AGENT_RUNS=false

# Experimental autonomous-run worker cadence.
# These apply only when ENABLE_EXPERIMENTAL_AGENT_RUNS=true and the HTTP server starts.
AGENT_RUN_WORKER_INTERVAL_MS=1000
AGENT_RUN_WORKER_BATCH_SIZE=25

# Preview token signing secret and default TTL.
# Required in production for stable preview issuance and verification.
PREVIEW_TOKEN_SECRET=
PREVIEW_TOKEN_TTL_SECONDS=900
